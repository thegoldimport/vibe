# Replit Environment Variables
# Copy these to the Replit Secrets tool

# Database (Replit's built-in Postgres or external Supabase)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Authentication
JWT_SECRET=

# AI Model Keys
GEMINI_API_KEY=
GOOGLE_API_KEY=

# App URL (if needed for callbacks)
NEXT_PUBLIC_APP_URL=
